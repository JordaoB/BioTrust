# BioTrust Backend Configuration
# Copy this file to .env and update with your values

# =====================================================================
# App Settings
# =====================================================================
APP_NAME=BioTrust
APP_VERSION=2.0.0
DEBUG=True
ENVIRONMENT=development

# =====================================================================
# MongoDB Database
# =====================================================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=biotrust
# Render/Cloud: use MongoDB Atlas URI, e.g. mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority

# =====================================================================
# Security (CHANGE THESE IN PRODUCTION!)
# =====================================================================
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption for card numbers (must be 32 bytes base64)
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-this

# =====================================================================
# API Server
# =====================================================================
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]

# CORS - Allowed origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:5500"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Requested-With"]

# Security hardening
SECURITY_HEADERS_ENABLED=True
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# =====================================================================
# Liveness Detection
# =====================================================================
LIVENESS_TIMEOUT_SECONDS=90
LIVENESS_ENABLE_PASSIVE=True

# =====================================================================
# Risk Engine Thresholds
# =====================================================================
RISK_HIGH_THRESHOLD=60
RISK_MEDIUM_THRESHOLD=26
LIVENESS_TRIGGER_THRESHOLD=26
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
